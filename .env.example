# Copy to .env and adjust if needed
HARBOR_HOST=harbor.local
HARBOR_HTTP_PORT=8080
HARBOR_HTTPS_PORT=8443
HARBOR_ADMIN_PASSWORD=Harbor12345
HARBOR_DB_PASSWORD=root123
HARBOR_VERSION=v2.10.2

# Default registry endpoint used by scripts
HARBOR_REGISTRY=harbor.local:8443

# Default project and sample image name/tag
HARBOR_PROJECT=demo
SAMPLE_IMAGE_NAME=demo-nginx
SAMPLE_IMAGE_TAG=1.0
